#!/usr/bin/env bash
# PreToolUse hook for Read: enforces the information barrier and auto-allows .rnd/ reads.
#
# Two responsibilities:
#   1. Information barrier — blocks reads of self-assessment files to prevent the
#      Verifier from anchoring on Builder reasoning. Self-assessment files are
#      write-only records for the orchestrator.
#   2. Auto-allow — permits all other reads targeting .rnd/ paths without prompting.
#
# Tool input is passed as JSON on stdin.
#
# Output convention:
#   Auto-allow: exit 0 + hookSpecificOutput JSON with permissionDecision=allow
#   Block:      exit 2 + reason on stderr
#   No opinion: exit 0 + no output

set -euo pipefail
source "$(dirname "$0")/lib.sh"

INPUT="$(cat)"
FILE="$(hook_file_path "$INPUT")"
AGENT="$(hook_agent_type "$INPUT")"

# Block self-assessment reads unless the requester is a known non-verifier agent.
# Absent/empty agent_type defaults to blocking for backward compat.
if echo "$FILE" | grep -iq 'self-assessment'; then
  if [ -n "$AGENT" ] && ! echo "$AGENT" | grep -iq 'verifier'; then
    : # known non-verifier — fall through to auto-allow check below
  else
    hook_block 'INFORMATION BARRIER: self-assessment files are write-only records for the orchestrator. Direct reading is blocked to maintain information barriers between Builder and Verifier.'
  fi
fi

if is_rnd_path "$FILE"; then
  hook_allow
fi
