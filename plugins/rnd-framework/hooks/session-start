#!/usr/bin/env bash
# SessionStart hook for rnd-framework plugin

set -euo pipefail
source "$(dirname "$0")/lib.sh"

# Compute RND_DIR via helper (creates directory structure with -c flag)
RND_DIR=$(resolve_rnd_dir -c)

# Check for version mismatch between cached plugin and source repo
VERSION_WARNING=""
CACHED_VERSION=$(jq -r '.version // empty' "${PLUGIN_ROOT}/.claude-plugin/plugin.json" 2>/dev/null || echo "")
if [ -n "$CACHED_VERSION" ]; then
  GIT_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || echo "")
  for source_path in \
    "${GIT_ROOT}/plugins/rnd-framework/.claude-plugin/plugin.json" \
    "${GIT_ROOT}/rnd-framework/.claude-plugin/plugin.json" \
    "${GIT_ROOT}/.claude-plugin/plugin.json"; do
    if [ -n "$GIT_ROOT" ] && [ -f "$source_path" ]; then
      SOURCE_NAME=$(jq -r '.name // empty' "$source_path" 2>/dev/null || echo "")
      if [ "$SOURCE_NAME" = "rnd-framework" ]; then
        SOURCE_VERSION=$(jq -r '.version // empty' "$source_path" 2>/dev/null || echo "")
        if [ -n "$SOURCE_VERSION" ] && [ "$SOURCE_VERSION" != "$CACHED_VERSION" ]; then
          VERSION_WARNING="\\n\\n⚠ **Plugin version mismatch:** cached v${CACHED_VERSION}, source v${SOURCE_VERSION}. Run \`/plugin update rnd-framework@rnd-framework-plugins\` to sync."
        fi
        break
      fi
    fi
  done
fi

# Extract session start timestamp from the RND_DIR path (YYYYMMDD-HHMMSS-XXXX)
SESSION_ID=$(basename "${RND_DIR:-}")
SESSION_TIMESTAMP=$(echo "$SESSION_ID" | grep -oE '^[0-9]{8}-[0-9]{6}' || echo "")

# Read using-rnd-framework content
using_rnd_content=$(cat "${PLUGIN_ROOT}/skills/using-rnd-framework/SKILL.md" 2>&1 || echo "Error reading using-rnd-framework skill")

# Build and output JSON using jq (handles all escaping correctly)
jq -n \
  --arg skill "$using_rnd_content" \
  --arg rnd_dir "${RND_DIR:-}" \
  --arg version_warning "$VERSION_WARNING" \
  --arg session_ts "${SESSION_TIMESTAMP:-}" \
  '
  (if $rnd_dir != "" then "\n\n**RND_DIR (pipeline artifact directory for this project):** `\($rnd_dir)`" else "" end) as $rnd_line |
  (if $session_ts != "" then "\n\n**Wellbeing cron:** Register a 30-minute recurring cron job using CronCreate. The cron prompt should check elapsed time since session start (\($session_ts)) and invoke the rnd-wellbeing skill to suggest a break if >90 minutes have passed." else "" end) as $cron_line |
  "<EXTREMELY_IMPORTANT>\nYou have rnd-framework.\n\n**Below is the full content of your '\''rnd-framework:using-rnd-framework'\'' skill - your introduction to using the R&D framework. For all other skills, use the '\''Skill'\'' tool:**\n\n\($skill)\($rnd_line)\($cron_line)\($version_warning)\n\n</EXTREMELY_IMPORTANT>" as $ctx |
  {
    additional_context: $ctx,
    hookSpecificOutput: {
      hookEventName: "SessionStart",
      additionalContext: $ctx
    }
  }
  '

exit 0
