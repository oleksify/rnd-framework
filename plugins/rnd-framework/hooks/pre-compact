#!/usr/bin/env bash
# PreCompact hook for rnd-framework plugin.
# Saves pipeline state to $RND_DIR/compact-state.json before context compaction.
#
# Fire-and-forget: exits 0 always, produces no stdout.
# Reads: plan.md, builds/T*-manifest.md, iteration-log.md

set -euo pipefail

# Guard missing dependencies before sourcing lib.sh.
command -v jq  >/dev/null 2>&1 || exit 0
command -v date >/dev/null 2>&1 || exit 0

source "$(dirname "$0")/lib.sh"

# Resolve active RND_DIR — must contain /sessions/ to be an active session.
RND_DIR=$(resolve_rnd_dir)
if [ -z "$RND_DIR" ] || [[ "$RND_DIR" != */sessions/* ]]; then
  exit 0
fi

[ ! -d "$RND_DIR" ] && exit 0

# Extract planSummary: first 5 lines of plan.md, or "no plan".
PLAN_FILE="${RND_DIR}/plan.md"
if [ -f "$PLAN_FILE" ]; then
  PLAN_SUMMARY=$(head -5 "$PLAN_FILE" 2>/dev/null || echo "no plan")
else
  PLAN_SUMMARY="no plan"
fi

# Extract currentTaskId: most recent builds/T*-manifest.md basename, or null.
LATEST_MANIFEST=$(ls -t "${RND_DIR}/builds/"T*-manifest.md 2>/dev/null | head -1 || echo "")
if [ -n "$LATEST_MANIFEST" ]; then
  MANIFEST_BASE=$(basename "$LATEST_MANIFEST")
  CURRENT_TASK_ID="${MANIFEST_BASE%%-manifest.md}"
else
  CURRENT_TASK_ID=""
fi

# Extract iterationCount: line count of iteration-log.md, or 0.
ITER_LOG="${RND_DIR}/iteration-log.md"
if [ -f "$ITER_LOG" ]; then
  ITER_COUNT=$(wc -l < "$ITER_LOG" 2>/dev/null || echo "0")
  ITER_COUNT="${ITER_COUNT// /}"
else
  ITER_COUNT="0"
fi

# Capture timestamp.
TS="$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null)" || true
[ -z "$TS" ] && exit 0

# Write compact-state.json using jq --arg to handle escaping.
jq -cn \
  --arg planSummary "$PLAN_SUMMARY" \
  --argjson currentTaskId "$([ -n "$CURRENT_TASK_ID" ] && printf '"%s"' "$CURRENT_TASK_ID" || echo 'null')" \
  --argjson iterationCount "$ITER_COUNT" \
  --arg savedAt "$TS" \
  '{planSummary: $planSummary, currentTaskId: $currentTaskId, iterationCount: $iterationCount, savedAt: $savedAt}' \
  > "${RND_DIR}/compact-state.json" 2>/dev/null || true

exit 0
