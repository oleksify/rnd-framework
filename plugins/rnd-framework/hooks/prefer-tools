#!/usr/bin/env bash
# PreToolUse hook for Bash: blocks sed/grep/cat/find/etc when
# dedicated Claude Code tools (Edit, Grep, Read, Glob) should be used instead.
#
# Only blocks when the tool is the LEADING command — piped usage is allowed.
# Tool input is passed as JSON on stdin (not via environment variables).
#
# Output convention (hookSpecificOutput format):
#   Auto-allow: exit 0 + hookSpecificOutput JSON with permissionDecision=allow
#   Block:      exit 2 + reason on stderr
#   No opinion: exit 0 + no output

set -euo pipefail
source "$(dirname "$0")/lib.sh"

INPUT="$(cat)"
COMMAND="$(hook_command "$INPUT")"

# Strip ALL leading "cd ... && " or "cd ... ; " prefixes (greedy, handles chained cd)
STRIPPED="$(echo "$COMMAND" | sed -E 's/^(cd[[:space:]]+[^&;]+([&;]+|&&)[[:space:]]*)+//')"

if echo "$STRIPPED" | grep -qE '^(sed|awk)\b'; then
  hook_block "Use the Edit tool instead of sed/awk. Edit is reviewable, diffable, and handles indentation correctly."
elif echo "$STRIPPED" | grep -qE '^(cat|head|tail)\b'; then
  hook_block "Use the Read tool instead of cat/head/tail. Read supports line offsets and limits natively."
elif echo "$STRIPPED" | grep -qE '^(grep|rg)\b'; then
  hook_block "Use the Grep tool instead of grep/rg. Grep supports regex, file globs, and output modes."
elif echo "$STRIPPED" | grep -qE '^find\b'; then
  hook_block "Use the Glob tool instead of find. Glob supports patterns like **/*.ts."
elif echo "$STRIPPED" | grep -qE '^(echo|printf)\b'; then
  # Block file redirects. Strip all > /dev/... and > .../.rnd/... occurrences,
  # then block if any unsafe redirect remains.
  WITHOUT_SAFE="$(echo "$STRIPPED" | sed -E 's/> *\/dev\/[^[:space:]]* ?//g; s/> *[^[:space:]]*\.rnd\/[^[:space:]]* ?//g')"
  if echo "$WITHOUT_SAFE" | grep -qE '>'; then
    hook_block "Use the Write tool instead of echo/printf with file redirects. Write is reviewable and creates proper diffs."
  fi
  hook_allow
elif echo "$COMMAND" | grep -qE 'git[[:space:]]+add.*\.rnd(/|[[:space:]]|$)'; then
  hook_block "BLOCKED: .rnd/ is a pipeline artifact directory and must never be committed."
else
  hook_allow
fi
