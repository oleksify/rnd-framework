{
  "allowWrite": [
    "~/.claude*/.rnd/**"
  ],
  "sandbox": {
    "network": {
      "deniedDomains": [
        "pastebin.com",
        "hastebin.com",
        "0x0.st",
        "transfer.sh"
      ]
    }
  },
  "showThinkingSummaries": true,
  "spinnerTipsEnabled": false,
  "spinnerVerbs": [
    "Planning",
    "Building",
    "Verifying",
    "Integrating",
    "Decomposing",
    "Analyzing"
  ],
  "statusLines": [
    {
      "command": "${CLAUDE_PLUGIN_ROOT}/hooks/statusline.sh",
      "refreshInterval": 5
    }
  ]
}
