#!/usr/bin/env bash
# SessionStart hook for rnd-framework plugin

set -euo pipefail

# Determine plugin root directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Compute RND_DIR via helper (creates directory structure with -c flag)
RND_DIR=$("${PLUGIN_ROOT}/lib/rnd-dir.sh" -c 2>/dev/null || echo "")

# Read using-rnd-framework content
using_rnd_content=$(cat "${PLUGIN_ROOT}/skills/using-rnd-framework/SKILL.md" 2>&1 || echo "Error reading using-rnd-framework skill")

# Build and output JSON using jq (handles all escaping correctly)
jq -n \
  --arg skill "$using_rnd_content" \
  --arg rnd_dir "${RND_DIR:-}" \
  '
  (if $rnd_dir != "" then "\n\n**RND_DIR (pipeline artifact directory for this project):** `\($rnd_dir)`" else "" end) as $rnd_line |
  "<EXTREMELY_IMPORTANT>\nYou have rnd-framework.\n\n**Below is the full content of your '\''rnd-framework:using-rnd-framework'\'' skill - your introduction to using the R&D framework. For all other skills, use the '\''Skill'\'' tool:**\n\n\($skill)\($rnd_line)\n\n</EXTREMELY_IMPORTANT>" as $ctx |
  {
    additional_context: $ctx,
    hookSpecificOutput: {
      hookEventName: "SessionStart",
      additionalContext: $ctx
    }
  }
  '

exit 0
