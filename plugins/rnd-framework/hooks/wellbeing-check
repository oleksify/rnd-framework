#!/usr/bin/env bash
# PostToolUse hook: checks elapsed time and suggests breaks.
# Resilient: always exit 0, never fail.

command -v date >/dev/null 2>&1 || exit 0

source "$(dirname "$0")/lib.sh"

RND_DIR=$(resolve_rnd_dir)
[ -z "$RND_DIR" ] || [[ "$RND_DIR" != */sessions/* ]] && exit 0

TS_FILE="${RND_DIR}/.wellbeing-ts"
NOW=$(date +%s 2>/dev/null) || exit 0

if [ -f "$TS_FILE" ]; then
  LAST=$(cat "$TS_FILE" 2>/dev/null) || exit 0
  DIFF=$((NOW - LAST))
  [ "$DIFF" -lt 2700 ] && exit 0
fi

printf '%s' "$NOW" > "$TS_FILE" 2>/dev/null || exit 0

jq -cn --arg ctx "You have been working for a while. Consider taking a 10-15 minute break — step away from the screen, stretch, look at something far away. Your focus quality improves after rest." \
  '{"hookSpecificOutput":{"additionalContext":$ctx}}' 2>/dev/null || exit 0

exit 0
