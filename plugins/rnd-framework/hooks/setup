#!/usr/bin/env bash
# Setup hook for rnd-framework plugin
# Fires via `claude --init` / `--init-only` / `--maintenance`.
# Reports plugin validation status and dependency availability.
# Always exits 0 — this is a status reporter, not a gate.

set -euo pipefail
source "$(dirname "$0")/lib.sh"

# Run validate.sh and capture pass/fail counts from individual check lines
VALIDATE_PASS=0
VALIDATE_FAIL=0
if validate_out=$("${PLUGIN_ROOT}/lib/validate.sh" 2>&1); then
  VALIDATE_STATUS="pass"
else
  VALIDATE_STATUS="fail"
fi
VALIDATE_PASS=$(echo "$validate_out" | grep -c '  PASS  ' || true)
VALIDATE_FAIL=$(echo "$validate_out" | grep -c '  FAIL  ' || true)

# Check bun availability
if command -v bun >/dev/null 2>&1; then
  BUN_VERSION=$(bun --version 2>/dev/null || echo "unknown")
  BUN_STATUS="available (${BUN_VERSION})"
else
  BUN_STATUS="not found"
fi

# Check jq availability
if command -v jq >/dev/null 2>&1; then
  JQ_VERSION=$(jq --version 2>/dev/null || echo "unknown")
  JQ_STATUS="available (${JQ_VERSION})"
else
  JQ_STATUS="not found"
fi

# Build and output status JSON
jq -n \
  --arg validate_status "$VALIDATE_STATUS" \
  --arg pass_count "$VALIDATE_PASS" \
  --arg fail_count "$VALIDATE_FAIL" \
  --arg bun_status "$BUN_STATUS" \
  --arg jq_status "$JQ_STATUS" \
  '
  "rnd-framework setup:\n  Validation: \($validate_status) (\($pass_count) pass, \($fail_count) fail)\n  bun: \($bun_status)\n  jq: \($jq_status)" as $ctx |
  { hookSpecificOutput: { hookEventName: "Setup", additionalContext: $ctx } }
  '

exit 0
