#!/usr/bin/env bun
// PostToolUse hook: slop-gate
//
// Reads the slop pattern catalog, analyzes code written by Write/Edit tools
// for structural anti-patterns, computes a scoring verdict, and outputs
// structured JSON feedback to stdout.
//
// Behavior:
//   - Write: analyzes tool_input.content (full file)
//   - Edit:  analyzes tool_input.new_string only (diff-aware)
//   - Non-code file extensions: exits 0, no output
//   - Malformed stdin, missing catalog, any error: exits 0, no output
//   - Always exits 0 (PostToolUse hooks are advisory)

import { resolve } from "node:path";
import { readFileSync, mkdirSync, writeFileSync } from "node:fs";
import { execSync } from "node:child_process";

// ---------------------------------------------------------------------------
// File extension allowlist (T3 logic)
// ---------------------------------------------------------------------------

const CODE_EXTENSIONS = new Set([
  ".ts", ".tsx", ".js", ".jsx", ".mjs", ".cjs",
  ".py", ".rb", ".go", ".rs", ".java",
  ".c", ".cpp", ".h", ".hpp", ".cs",
  ".swift", ".kt", ".scala",
  ".sh", ".bash", ".zsh", ".fish",
  ".lua", ".php", ".vue", ".svelte",
  ".ex", ".exs",
]);

// ---------------------------------------------------------------------------
// Types
// ---------------------------------------------------------------------------

interface SlopPattern {
  id: string;
  name: string;
  regex: string;
  severity: number;
  category: string;
  description: string;
  remediation: string;
}

interface PatternCatalog {
  patterns: SlopPattern[];
}

interface Match {
  pattern_id: string;
  line: number;
  snippet: string;
  severity: number;
}

type Verdict = "PASS" | "WARN" | "FAIL";

interface HookOutput {
  verdict: Verdict;
  score: number;
  file_path: string;
  line_count: number;
  matches: Match[];
}

// ---------------------------------------------------------------------------
// Scoring thresholds
// ---------------------------------------------------------------------------

const WARN_THRESHOLD = 3;
const FAIL_THRESHOLD = 7;

function computeVerdict(score: number): Verdict {
  if (score > FAIL_THRESHOLD) return "FAIL";
  if (score >= WARN_THRESHOLD) return "WARN";
  return "PASS";
}

// ---------------------------------------------------------------------------
// File extension check
// ---------------------------------------------------------------------------

function isCodeFile(filePath: string): boolean {
  const lastDot = filePath.lastIndexOf(".");
  if (lastDot === -1) return false;
  const ext = filePath.slice(lastDot).toLowerCase();
  return CODE_EXTENSIONS.has(ext);
}

// ---------------------------------------------------------------------------
// Pattern analysis
// ---------------------------------------------------------------------------

function analyzeContent(content: string, patterns: SlopPattern[]): Match[] {
  const lines = content.split("\n");
  const matches: Match[] = [];

  for (const pattern of patterns) {
    let regex: RegExp;
    try {
      regex = new RegExp(pattern.regex);
    } catch {
      // Skip invalid regex patterns — catalog integrity is not our job here
      continue;
    }

    for (let i = 0; i < lines.length; i++) {
      const line = lines[i];
      if (regex.test(line)) {
        // Truncate snippet to 120 chars to keep output manageable
        const snippet = line.trim().slice(0, 120);
        matches.push({
          pattern_id: pattern.id,
          line: i + 1,
          snippet,
          severity: pattern.severity,
        });
      }
    }
  }

  return matches;
}

// ---------------------------------------------------------------------------
// Score computation
// ---------------------------------------------------------------------------

function computeScore(matches: Match[], lineCount: number): number {
  if (lineCount === 0) return 0;
  const rawScore = matches.reduce((sum, m) => sum + m.severity, 0);
  return rawScore / lineCount;
}

// ---------------------------------------------------------------------------
// Pipeline artifact types
// ---------------------------------------------------------------------------

interface SlopReport {
  file_path: string;
  verdict: Verdict;
  score: number;
  matches: Match[];
  line_count: number;
  timestamp: string;
}

interface CumulativeScore {
  total_score: number;
  file_count: number;
  average_score: number;
  worst_file: string;
  worst_score: number;
}

// ---------------------------------------------------------------------------
// Filename sanitization
// ---------------------------------------------------------------------------

/**
 * Sanitizes a file path into a safe filename.
 * /src/utils/foo.ts => src-utils-foo.ts.json
 * (leading slash stripped, internal slashes become dashes, .json appended)
 */
function sanitizePathToFilename(filePath: string): string {
  const stripped = filePath.replace(/^\/+/, "").replace(/\//g, "-");
  return `${stripped}.json`;
}

// ---------------------------------------------------------------------------
// RND_DIR resolution
// ---------------------------------------------------------------------------

/**
 * Resolves the active session directory by running lib/rnd-dir.sh.
 * Returns the path if it points to an active session (contains /sessions/),
 * or null if there is no active session or resolution fails.
 */
function resolveActiveSessionDir(): string | null {
  try {
    const rndDirScript = resolve(import.meta.dir, "..", "lib", "rnd-dir.sh");
    const rndDir = execSync(`"${rndDirScript}"`, {
      encoding: "utf-8",
      timeout: 5000,
    }).trim();
    if (rndDir.includes("/sessions/")) {
      return rndDir;
    }
    return null;
  } catch {
    return null;
  }
}

// ---------------------------------------------------------------------------
// Artifact writing
// ---------------------------------------------------------------------------

/**
 * Writes per-file slop report and updates cumulative score file.
 * Silently no-ops on any error — artifact writing must never fail the hook.
 */
function writePipelineArtifacts(output: HookOutput): void {
  const sessionDir = resolveActiveSessionDir();
  if (sessionDir === null) {
    return;
  }

  try {
    const reportsDir = resolve(sessionDir, "slop-reports");
    mkdirSync(reportsDir, { recursive: true });

    // Per-file report
    const report: SlopReport = {
      file_path: output.file_path,
      verdict: output.verdict,
      score: output.score,
      matches: output.matches,
      line_count: output.line_count,
      timestamp: new Date().toISOString(),
    };

    const reportFilename = sanitizePathToFilename(output.file_path);
    const reportPath = resolve(reportsDir, reportFilename);
    writeFileSync(reportPath, JSON.stringify(report, null, 2), "utf-8");

    // Cumulative score
    const cumulativePath = resolve(reportsDir, "cumulative-score.json");
    let cumulative: CumulativeScore;

    try {
      const existing = readFileSync(cumulativePath, "utf-8");
      cumulative = JSON.parse(existing) as CumulativeScore;
    } catch {
      cumulative = {
        total_score: 0,
        file_count: 0,
        average_score: 0,
        worst_file: "",
        worst_score: 0,
      };
    }

    cumulative.total_score += output.score;
    cumulative.file_count += 1;
    cumulative.average_score = cumulative.total_score / cumulative.file_count;

    if (output.score > cumulative.worst_score) {
      cumulative.worst_score = output.score;
      cumulative.worst_file = output.file_path;
    }

    writeFileSync(cumulativePath, JSON.stringify(cumulative, null, 2), "utf-8");
  } catch {
    // Swallow all errors — artifact writing must never fail the hook
  }
}

// ---------------------------------------------------------------------------
// Main
// ---------------------------------------------------------------------------

async function main(): Promise<void> {
  // Read all stdin
  const stdinChunks: Uint8Array[] = [];
  for await (const chunk of Bun.stdin.stream()) {
    stdinChunks.push(chunk);
  }
  const stdinText = new TextDecoder().decode(
    stdinChunks.reduce((acc, chunk) => {
      const merged = new Uint8Array(acc.length + chunk.length);
      merged.set(acc, 0);
      merged.set(chunk, acc.length);
      return merged;
    }, new Uint8Array(0)),
  );

  // Parse stdin JSON
  let input: Record<string, unknown>;
  try {
    const parsed = JSON.parse(stdinText);
    if (typeof parsed !== "object" || parsed === null || Array.isArray(parsed)) {
      process.exit(0);
    }
    input = parsed as Record<string, unknown>;
  } catch {
    process.exit(0);
  }

  // Extract tool name and tool_input
  const toolName = input["tool_name"];
  const toolInput = input["tool_input"];

  if (
    typeof toolName !== "string" ||
    typeof toolInput !== "object" ||
    toolInput === null ||
    Array.isArray(toolInput)
  ) {
    process.exit(0);
  }

  const toolInputObj = toolInput as Record<string, unknown>;

  // Extract file path
  const filePath = toolInputObj["file_path"];
  if (typeof filePath !== "string" || filePath.length === 0) {
    process.exit(0);
  }

  // Skip non-code files (T3)
  if (!isCodeFile(filePath)) {
    process.exit(0);
  }

  // Determine content to analyze (diff-aware)
  let content: string;
  if (toolName === "Write") {
    const c = toolInputObj["content"];
    if (typeof c !== "string") {
      process.exit(0);
    }
    content = c;
  } else if (toolName === "Edit") {
    const ns = toolInputObj["new_string"];
    if (typeof ns !== "string") {
      process.exit(0);
    }
    content = ns;
  } else {
    // Not a Write or Edit — nothing to analyze
    process.exit(0);
  }

  // Load pattern catalog
  const catalogPath = resolve(import.meta.dir, "..", "slop-patterns.json");
  let catalog: PatternCatalog;
  try {
    const raw = readFileSync(catalogPath, "utf-8");
    const parsed = JSON.parse(raw);
    if (
      typeof parsed !== "object" ||
      parsed === null ||
      !Array.isArray(parsed.patterns)
    ) {
      process.exit(0);
    }
    catalog = parsed as PatternCatalog;
  } catch {
    process.exit(0);
  }

  // Merge project-specific patterns from $RND_DIR/project-patterns.json
  const sessionDir = resolveActiveSessionDir();
  if (sessionDir !== null) {
    try {
      const projectCatalogPath = resolve(sessionDir, "project-patterns.json");
      const raw = readFileSync(projectCatalogPath, "utf-8");
      const parsed = JSON.parse(raw);
      if (
        typeof parsed === "object" &&
        parsed !== null &&
        Array.isArray(parsed.patterns)
      ) {
        catalog = { patterns: catalog.patterns.concat(parsed.patterns as SlopPattern[]) };
      }
    } catch {
      // Missing or malformed project-patterns.json — silently continue with built-in only
    }
  }

  // Analyze content
  const matches = analyzeContent(content, catalog.patterns);
  const lines = content.split("\n");
  const lineCount = lines.length;
  const score = computeScore(matches, lineCount);
  const verdict = computeVerdict(score);

  const output: HookOutput = {
    verdict,
    score,
    file_path: filePath,
    line_count: lineCount,
    matches,
  };

  // Save pipeline artifacts if an active session exists (T4)
  writePipelineArtifacts(output);

  process.stdout.write(JSON.stringify(output) + "\n");
}

try {
  await main();
} catch {
  // Top-level catch: guarantee exit 0 regardless of any unhandled error
  process.exit(0);
}
