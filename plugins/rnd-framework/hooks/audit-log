#!/usr/bin/env bash
# PostToolUse hook for Write and Edit:
#   Appends a JSONL audit entry to $RND_DIR/audit.jsonl for every file write/edit
#   during an active pipeline session.
#
# Tool input is passed as JSON on stdin.
#
# Output convention:
#   Resilient: always exit 0, never fail.

# Guard missing dependencies — resilient hook, must never fail.
command -v jq  >/dev/null 2>&1 || exit 0
command -v date >/dev/null 2>&1 || exit 0

source "$(dirname "$0")/lib.sh"

INPUT="$(cat)"
FILE="$(hook_file_path "$INPUT")"
TOOL="$(hook_tool_name "$INPUT")"

# When jq fails to parse (malformed JSON), FILE and TOOL will be empty.
if [ -z "$FILE" ] || [ -z "$TOOL" ]; then
  exit 0
fi

# Resolve active RND_DIR — must contain /sessions/ to be an active session.
RND_DIR=$(resolve_rnd_dir)
if [ -z "$RND_DIR" ] || [[ "$RND_DIR" != */sessions/* ]]; then
  exit 0
fi

[ ! -d "$RND_DIR" ] && exit 0

# Capture timestamp — exit 0 silently if date fails.
TS="$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null)" || true
[ -z "$TS" ] && exit 0

# Append JSONL entry — use jq -n --arg to prevent injection.
jq -cn --arg ts "$TS" --arg tool "$TOOL" --arg file "$FILE" \
  '{"ts":$ts,"tool":$tool,"file":$file}' >> "${RND_DIR}/audit.jsonl" 2>/dev/null || true

exit 0
