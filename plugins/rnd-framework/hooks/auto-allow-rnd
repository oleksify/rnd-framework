#!/usr/bin/env bash
# PreToolUse hook for Write and Edit:
#   1. Auto-allows operations targeting .rnd/ paths (framework artifacts).
#   2. Blocks non-.rnd/ writes during planning phase (marker file check).
#
# Tool input is passed as JSON on stdin.
#
# Output convention:
#   Auto-allow: exit 0 + hookSpecificOutput JSON with permissionDecision=allow
#   Block:      exit 2 + reason on stderr
#   No opinion: exit 0 + no output

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

INPUT="$(cat)"
FILE="$(echo "$INPUT" | jq -r '.tool_input.file_path // empty' 2>/dev/null)"

# .rnd/ path detection uses substring matching — any path containing the string ".rnd/"
# is treated as a framework artifact and auto-allowed. This is an accepted trade-off:
# a project file with ".rnd/" in its path would be incorrectly auto-allowed, but such
# paths are extremely unlikely in practice and the false-negative risk (blocking legitimate
# artifact writes) is more harmful than the false-positive risk.
if echo "$FILE" | grep -q '\.rnd/'; then
  echo '{"hookSpecificOutput":{"hookEventName":"PreToolUse","permissionDecision":"allow"}}'
else
  # Check planning-phase marker: block all writes outside .rnd/ during planning
  RND_DIR=$("${PLUGIN_ROOT}/lib/rnd-dir.sh" 2>/dev/null || echo "")
  if [ -n "$RND_DIR" ] && [ -f "${RND_DIR}/.planning-phase" ]; then
    echo "BLOCKED: Write/Edit to paths outside .rnd/ is not allowed during the planning phase. The Planner writes only to \$RND_DIR/plan.md." >&2
    exit 2
  fi
fi
