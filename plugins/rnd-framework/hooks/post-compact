#!/usr/bin/env bash
# PostCompact hook for rnd-framework plugin.
# Re-injects pipeline state after context compaction by reading compact-state.json
# and outputting it as hookSpecificOutput.additionalContext.
#
# Resilient: always exit 0, never fail.

# Guard missing dependencies — resilient hook, must never fail.
command -v jq >/dev/null 2>&1 || exit 0

source "$(dirname "$0")/lib.sh"

# Resolve active RND_DIR — must contain /sessions/ to be an active session.
RND_DIR=$(resolve_rnd_dir)
if [ -z "$RND_DIR" ] || [[ "$RND_DIR" != */sessions/* ]]; then
  exit 0
fi

STATE_FILE="${RND_DIR}/compact-state.json"
[ ! -f "$STATE_FILE" ] && exit 0

# Attempt to parse compact-state.json — exit 0 silently on malformed JSON.
PLAN=$(jq -r '.planSummary // empty' "$STATE_FILE" 2>/dev/null) || exit 0
TASK=$(jq -r '.currentTaskId // "unknown"' "$STATE_FILE" 2>/dev/null) || exit 0
ITER=$(jq -r '.iterationCount // "0"' "$STATE_FILE" 2>/dev/null) || exit 0
SAVED=$(jq -r '.savedAt // "unknown"' "$STATE_FILE" 2>/dev/null) || exit 0

# If jq parsed successfully but planSummary is missing, output nothing.
[ -z "$PLAN" ] && exit 0

# Build context message and emit JSON.
MSG="Pipeline state restored after compaction:\n  Plan: ${PLAN}\n  Current task: ${TASK}\n  Iteration: ${ITER}\n  State saved at: ${SAVED}"

jq -cn --arg ctx "$MSG" \
  '{"hookSpecificOutput":{"additionalContext":$ctx}}' 2>/dev/null || exit 0

exit 0
